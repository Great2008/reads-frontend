{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://reads-backend-dwk9.onrender.com/api/:path*"
    },
    {
      "source": "/((?!assets|favicon.ico|sw.js|pwa-).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}