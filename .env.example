# $READS Frontend Environment Variables
# Copy this file to .env and fill in your values

# Vite exposes vars prefixed with VITE_ to the browser
VITE_API_URL=https://your-backend.onrender.com
VITE_APP_NAME=$READS
VITE_APP_VERSION=2.0.0

# VAPID public key for push notifications (base64url)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Cardano network (mainnet | preprod | preview)
VITE_CARDANO_NETWORK=preprod
